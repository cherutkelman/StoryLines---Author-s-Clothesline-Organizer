rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: documents
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - authorId: string (required, UID)
    //   - segments: list (required, max 1000 items)
    //     - Segment: map
    //       - id: string (required)
    //       - text: string (required, max 5000 chars)
    //       - status: string (required, enum: ['accepted', 'suggested_addition', 'suggested_deletion'])
    //       - userId: string (required, UID)
    //       - userName: string (required, max 100 chars)
    //       - timestamp: timestamp (required)
    //   - lastUpdated: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner(docData) {
      return isAuthenticated() && request.auth.uid == docData.authorId;
    }

    function isValidSegment(segment) {
      return segment.id is string &&
             segment.text is string && segment.text.size() <= 5000 &&
             segment.status in ['accepted', 'suggested_addition', 'suggested_deletion'] &&
             segment.userId is string &&
             segment.userName is string && segment.userName.size() <= 100 &&
             segment.timestamp is timestamp;
    }

    function isValidDocument(data) {
      return data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             data.authorId is string &&
             data.segments is list && data.segments.size() <= 1000 &&
             data.lastUpdated is timestamp;
    }

    function isValidBook(data) {
      return data.id is string &&
             data.ownerId is string &&
             data.title is string &&
             data.plotlines is list &&
             data.scenes is list &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "cherut13@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /documents/{docId} {
      // Anyone authenticated can read documents
      allow read: if isAuthenticated();

      // Only authenticated users can create documents, and they must be the author
      allow create: if isAuthenticated() &&
                      isValidDocument(request.resource.data) &&
                      request.resource.data.authorId == request.auth.uid;

      // Update rules:
      // 1. Owners can update anything (as long as it's valid)
      // 2. Others can only update if they are adding/modifying suggestions (for simplicity, we allow any valid update if authenticated, but in a real app we'd restrict further)
      // Actually, for "Track Changes", any collaborator needs to be able to push their suggestions to the segments array.
      allow update: if isAuthenticated() &&
                      isValidDocument(request.resource.data) &&
                      (isDocOwner(resource.data) || (request.resource.data.authorId == resource.data.authorId));

      allow delete: if isDocOwner(resource.data) || isAdmin();
    }

    match /books/{bookId} {
      // Users can only access their own books
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId) && isValidBook(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && 
                      isOwner(request.resource.data.ownerId) && 
                      isValidBook(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
